{
  "name": "fchoir-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:site": "next dev",
    "build:site": "next lint && next build",
    "deploy:site": "gcloud storage rsync ./out gs://f-choir-website-static --recursive --delete-unmatched-destination-objects",
    "serve:site": "http-server ./out",
    "start:site": "next start",
    "lint": "next lint",
    "storybook:site": "storybook dev -p 6006",
    "build-storybook:site": "storybook build",
    "make-galleries": "node ./gcloud/makeGalleries.js"
  },
  "dependencies": {
    "classnames": "^2.3.2",
    "next": "14.0.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@storybook/addon-essentials": "7.5.3",
    "@storybook/addon-interactions": "7.5.3",
    "@storybook/addon-links": "7.5.3",
    "@storybook/addon-onboarding": "1.0.8",
    "@storybook/blocks": "7.5.3",
    "@storybook/nextjs": "7.5.3",
    "@storybook/react": "7.5.3",
    "@storybook/testing-library": "0.2.2",
    "@types/node": "20",
    "@types/react": "18",
    "@types/react-dom": "18",
    "autoprefixer": "10.0.1",
    "eslint": "8",
    "eslint-config-next": "14.0.3",
    "eslint-plugin-storybook": "0.6.15",
    "http-server": "14.1.1",
    "postcss": "8",
    "prettier": "3.1.0",
    "storybook": "7.5.3",
    "tailwindcss": "3.3.0",
    "ts-node": "10.9.1",
    "typescript": "5"
  },
  "packageManager": "yarn@4.0.2"
}
